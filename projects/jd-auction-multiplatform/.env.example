# AI model selection. Copy this file to .env and fill secrets locally.
# Priority: CLI arguments > MySQL ai_model_profiles > .env > built-in defaults.

AI_ACTIVE_PROFILE=qwen

# Generic fallback profile.
AI_PROVIDER=qwen
AI_MODEL_NAME=qwen-plus
AI_VISION_MODEL=qwen-vl-plus
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com
AI_TIMEOUT=0
AI_MAX_RETRIES=0
AI_QPS=10

# DeepSeek profile.
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL_NAME=deepseek-chat
AI_DEEPSEEK_VISION_MODEL=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen profile.
AI_QWEN_API_KEY=
AI_QWEN_MODEL_NAME=qwen-plus
AI_QWEN_VISION_MODEL=qwen-vl-plus
AI_QWEN_BASE_URL=https://dashscope.aliyuncs.com

# OpenAI profile.
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL_NAME=gpt-4o-mini
AI_OPENAI_VISION_MODEL=gpt-4o-mini
AI_OPENAI_BASE_URL=https://api.openai.com

# Public client parameters discovered from platform front-end pages.
# Keep real private credentials out of git; override here only for local testing.
ALI_MTOP_APP_KEY=24679788
GXCQ_LIST_APP_SECRET=PHPCMFA0EF8F01A56FF
